# 数字遗产管家后端配置

# 服务器端口
#PORT=3000
#NODE_ENV=development

# 密码学配置
#PRIME_NUMBER=115792089237316195423570985008687907853269984665640564039457584007913129639747
#FIELD_SIZE=256

# 智能合约配置
#CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
#CHAIN_ID=1

# IPFS配置（模拟）
#IPFS_GATEWAY=https://ipfs.io/ipfs/

# SMTP邮件配置（可选，不配置则使用控制台输出模拟）
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASS=your-password
# SMTP_FROM=Digital Legacy Guardian <noreply@example.com>

# 示例配置（QQ邮箱）
# SMTP_HOST=smtp.qq.com
# SMTP_PORT=587
# SMTP_USER=your-qq@qq.com
# SMTP_PASS=your-authorization-code
# SMTP_FROM=your-qq@qq.com

# 示例配置（163邮箱）
# SMTP_HOST=smtp.163.com
# SMTP_PORT=587
# SMTP_USER=your-email@163.com
# SMTP_PASS=your-authorization-code
# SMTP_FROM=your-email@163.com

# 示例配置（Gmail）
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# Deepseek AI API配置（用于AI助手功能）
# DEEPSEEK_API_KEY=your-deepseek-api-key
# DEEPSEEK_API_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-chat
